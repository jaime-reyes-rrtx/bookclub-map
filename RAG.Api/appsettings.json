{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Rag": {
    "DatabasePath": "../data/rag.db",
    "Storage": {
      "Provider": "S3",
      "Bucket": "rag-documents",
      "ServiceUrl": "http://localhost:9000",
      "AccessKey": "minioadmin",
      "SecretKey": "minioadmin",
      "Region": "us-east-1"
    },
    "Ai": {
      "Provider": "Ollama",
      "BaseUrl": "http://localhost:11434",
      "EmbeddingModel": "nomic-embed-text",
      "ChatModel": "llama3.2",
      "TimeoutSeconds": 180
    },
    "Qdrant": {
      "BaseUrl": "http://localhost:6333",
      "CollectionName": "rag_chunks",
      "VectorSize": 768
    },
    "Ingestion": {
      "ChunkTokenCount": 800,
      "ChunkOverlapTokens": 100,
      "MaxUploadBytes": 104857600,
      "PollIntervalSeconds": 5
    },
    "Request": {
      "MaxQuestionCharacters": 2000,
      "MaxSelectedDocuments": 20,
      "MaxRetrievalQueries": 12,
      "ProviderTimeoutSeconds": 90
    }
  }
}
